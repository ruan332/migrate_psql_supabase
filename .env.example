# ============================================================
# BANCO DE ORIGEM — PostgreSQL
# ============================================================
PG_HOST=192.168.1.100
PG_PORT=5432
PG_DBNAME=meu_banco
PG_USER=postgres
PG_PASSWORD=senha_origem

# ============================================================
# BANCO DE DESTINO — Supabase (conexão direta PostgreSQL)
# Encontre em: Supabase Dashboard > Project Settings > Database
# ============================================================
SUPA_HOST=db.xxxxxxxxxxxx.supabase.co
SUPA_PORT=5432
SUPA_DBNAME=postgres
SUPA_USER=postgres
SUPA_PASSWORD=senha_supabase

# ============================================================
# CONFIGURAÇÕES OPCIONAIS
# ============================================================
BATCH_SIZE=1000
EXCLUDE_SCHEMAS=pg_temp,pg_toast
EXCLUDE_TABLES=
LOG_LEVEL=INFO
